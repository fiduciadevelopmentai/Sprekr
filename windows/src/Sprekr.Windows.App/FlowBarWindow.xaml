<Window x:Class="Sprekr.Windows.App.FlowBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" Height="52" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" ShowActivated="False" Topmost="True"
        ResizeMode="NoResize">
    <Border CornerRadius="18" Background="#EE1F2026" BorderBrush="#447457E8" BorderThickness="1" Padding="16,10">
        <DockPanel>
            <Ellipse x:Name="StateDot" Width="10" Height="10" Fill="#7457E8" Margin="0,0,10,0" />
            <TextBlock x:Name="StateText" Foreground="White" FontSize="14" FontWeight="Medium"
                       VerticalAlignment="Center" Text="Sprekr is gereed" TextTrimming="CharacterEllipsis" />
        </DockPanel>
    </Border>
</Window>
